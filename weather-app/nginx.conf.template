server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy for Open-Meteo API (CORS)
    location /api/weather/ {
        proxy_pass https://api.open-meteo.com/;
        proxy_set_header Host api.open-meteo.com;
        proxy_set_header Accept-Encoding "";
    }

    # Proxy for Open-Meteo Geocoding API (CORS)
    location /api/geocoding/ {
        proxy_pass https://geocoding-api.open-meteo.com/;
        proxy_set_header Host geocoding-api.open-meteo.com;
    }

    # Proxy for LLM API
    location /api/nvidia/ {
        rewrite ^/api/nvidia/(.*)$ /$1 break;
        proxy_pass ${VITE_LLM_ENDPOINT};
        proxy_set_header Authorization "Bearer ${VITE_NVIDIA_API_KEY}";
        proxy_set_header Content-Type application/json;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}